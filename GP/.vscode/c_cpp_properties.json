{
    "env": {
        "commonIncludePaths": [
            "${workspaceFolder}/**",
            "${workspaceFolder}/../**",
            "${workspaceFolder}/../../third_party/**",
            "${workspaceFolder}/../../old_skxx_ui/third_party/skia/src/skia/**",
            "${workspaceFolder}/../third_party/iPlug2OOS/iPlug2/WDL/**",
            "${workspaceFolder}/../third_party/iPlug2OOS/iPlug2/IPlug/**",
            "${workspaceFolder}/../third_party/iPlug2OOS/iPlug2/Dependencies/**"
        ],
        "commonDefs": [
            "APP_API",
            "IPLUG_DSP=1",
            "IPLUG_EDITOR=1",
            "NO_IGRAPHICS",
            "IGRAPHICS_SKIA",
            "GLINT_RENDER_GPU",
            "NOMINMAX"
        ]
      },
    "configurations": [
        {
            "name": "Mac",
            "includePath": [
                "${commonIncludePaths}",
                "${workspaceFolder}/../../Dependencies/Build/mac/include/**"
            ],
            "defines": [
                "${commonDefs}",
                "OS_MAC"
            ],
            "macFrameworkPath": [
                "/System/Library/Frameworks",
                "/Library/Frameworks"
            ],
            "cppStandard": "c++14"
        },
        {
            "name": "Win32",
            "includePath": [
                "${commonIncludePaths}"
            ],
            "defines": [
                "${commonDefs}",
                "OS_WIN"
            ]
        }
    ],
    "version": 4
}